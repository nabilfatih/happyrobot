HAPPYROBOT_API_KEY=replace-with-long-random-api-key
# Optional rotation form: HAPPYROBOT_API_KEY=key-one,key-two
DASHBOARD_BASIC_USER=ops
DASHBOARD_BASIC_PASSWORD=replace-with-dashboard-password
DASHBOARD_REALTIME_TOKEN=replace-with-long-random-dashboard-realtime-token
CONVEX_URL=https://replace-with-deployment.convex.cloud
CONVEX_BACKEND_KEY=replace-with-long-random-backend-key

