{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "#/*": ["../src/*"],
      "@/*": ["../src/*"]
    },
    "resolveJsonModule": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": ["./**/*", "../confect/**/*", "../src/domain/**/*"]
}
